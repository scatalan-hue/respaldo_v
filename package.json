{
  "name": "base",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "SET TZ=America/Bogota&&nest start",
    "start:dev": "SET TZ=America/Bogota&&nest start --watch",
    "start:debug": "SET TZ=America/Bogota&&nest start --debug --watch",
    "start:prod": "SET TZ=America/Bogota&&node dist/main",
    "docker:start": "npm run docker:build && npm run docker:update",
    "docker:build": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && docker build . -t $DOCKER_IMAGE_NESTJS --no-cache --build-arg TZ=$TZ\"",
    "docker:update": "docker compose up -d --build",
    "docker:run": "node dist/main",
    "kube:start": "npm run envsubst:start && npm run docker:build && npm run kube:env && npm run kube:update",
    "kube:env": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && kubectl create configmap env-$KUBE_NAME_APP --namespace=$KUBE_NAME_SPACE --from-env-file=.env --dry-run=client -o yaml > kubernetes/env.configmap.yml\"",
    "kube:apply": "kubectl apply -f kubernetes/env.configmap.yml && kubectl apply -f kubernetes/app.service.yml && kubectl apply -f kubernetes/app.deployment.yml",
    "kube:update": "npm run kube:env && npm run envsubst:start && npm run kube:apply && npm run kube:restar",
    "kube:restar": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && kubectl rollout restart -n $KUBE_NAME_SPACE deployment app-$KUBE_NAME_APP\"",
    "kube:rollback": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && REV=$(kubectl rollout history deployment/app-$KUBE_NAME_APP -n $KUBE_NAME_SPACE | tail -n 4 | head -n 1 | awk '{print $1}') && kubectl rollout undo deployment/app-$KUBE_NAME_APP -n $KUBE_NAME_SPACE --to-revision=$REV \"",
    "kube:create-space": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && kubectl create ns $KUBE_NAME_SPACE\"",
    "kube:dashboard": "kubectl apply -f kubernetes/dashboard.yml && npm run kube:token && kubectl proxy",
    "kube:token": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && echo ' *** TOKEN *** ' && kubectl -n kubernetes-dashboard create token $KUBE_DASHBOARD_USERNAME\"",
    "envsubst:start": "npm run envsubst:service && npm run envsubst:dashboard && npm run envsubst:deployment",
    "envsubst:service": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && envsubst < kubernetes/templates/app.service.template.yml > kubernetes/app.service.yml\"",
    "envsubst:deployment": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && envsubst < kubernetes/templates/app.deployment.template.yml > kubernetes/app.deployment.yml\"",
    "envsubst:dashboard": "bash -c \"export $(grep -v '^#' .env | grep -v '^$' | xargs) && envsubst < kubernetes/templates/dashboard.template.yml > kubernetes/dashboard.yml\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "SET TZ=America/Bogota&&jest",
    "test:watch": "SET TZ=America/Bogota&&jest --watch",
    "test:cov": "SET TZ=America/Bogota&&jest --coverage",
    "test:debug": "SET TZ=America/Bogota&&node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "SET TZ=America/Bogota&&jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:cli": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:generate": "npm run typeorm:cli -- migration:generate -d src/database/ormconfig.ts src/database/migrations/migration & ts-node ./src/database/generate-migrations.ts",
    "typeorm:sync": "npm run typeorm:cli -- migration:generate -d src/database/ormconfig.ts src/database/migrations/migration & ts-node ./src/database/generate-migrations.ts",
    "typeorm:create": "npm run typeorm:cli migration:create -n",
    "typeorm:run": "npm run typeorm:cli -- migration:run -d src/database/ormconfig.ts",
    "typeorm:revert": "npm run typeorm:cli migration:revert",
    "typeorm:show": "npm run typeorm:cli migration:show",
    "typeorm:check": "npm run typeorm:cli schema:log",
    "view-entity": "node extract-view-entity.js"
  },
  "dependencies": {
    "@apollo/server": "^4.9.4",
    "@apollo/server-plugin-landing-page-graphql-playground": "^4.0.1",
    "@graphql-tools/schema": "^10.0.2",
    "@nestjs/apollo": "^12.0.9",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/class-transformer": "^0.4.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.2",
    "@nestjs/graphql": "^12.0.9",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^10.0.1",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.1.13",
    "@nestjs/typeorm": "^10.0.0",
    "@types/multer-gridfs-storage": "^4.0.7",
    "apollo-server-core": "^3.12.1",
    "apollo-server-express": "^3.13.0",
    "async-mutex": "^0.5.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.11.4",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron": "^3.5.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "file-type": "^16.5.4",
    "graphql": "^16.8.1",
    "graphql-redis-subscriptions": "^2.6.1",
    "graphql-subscriptions": "^2.0.0",
    "graphql-type-json": "^0.3.2",
    "graphql-upload": "^17.0.0",
    "graphql-upload-ts": "^2.1.0",
    "graphql-ws": "^5.14.2",
    "htmlparser2": "^9.1.0",
    "ipfs-http-gateway": "0.9.3",
    "joi": "^17.11.0",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "magic-bytes.js": "^1.10.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mongo-gridfs": "^1.1.0",
    "mongodb": "^5.9.1",
    "mongoose": "^6.12.1",
    "mssql": "^9.3.2",
    "multer-gridfs-storage": "^5.0.2",
    "nest-winston": "^1.9.7",
    "nestjs-i18n": "^10.4.0",
    "p-map": "^7.0.4",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "typeorm": "^0.3.17",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.0",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.10",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageReporters": [
      "json",
      "html"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}
